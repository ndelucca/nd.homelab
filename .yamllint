---
# yamllint configuration for the home-server Ansible project.
extends: default

rules:
  # Ansible files are often wide (long module args, vault blocks).
  line-length:
    max: 160
    level: warning
  # Allow inline comments closer to content than the strict default.
  comments:
    min-spaces-from-content: 1
  # ansible-lint exige prohibir valores octales (los modes de archivo van como
  # string "0644"); habilitarlo también re-activa el fix mode de ansible-lint.
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  comments-indentation: disable
  # Ansible booleans are true/false; don't fight yes/no edge cases hard.
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false
  # Files start with `---`; keep that required.
  document-start:
    present: true
  # Allow the idiomatic Ansible inline-map style: `{ key: value }`.
  braces:
    max-spaces-inside: 1

ignore: |
  .ansible/
  *.j2
  vendor/
  collections/  # colecciones instaladas por ansible-galaxy (código de terceros)
