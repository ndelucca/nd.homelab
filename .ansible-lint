---
# ansible-lint configuration for the home-server project.
# Start at the "moderate" profile; tighten to "production" once the
# backlog (see plan: version pins, changed_when guards) is cleared.
profile: moderate

exclude_paths:
  - .ansible/
  - .github/
  - vendor/  # Mitogen vendorizado (código de terceros)

# Rules intentionally relaxed for a single-maintainer home-lab. Remove
# entries as the corresponding cleanups land.
skip_list:
  - yaml[line-length]  # handled by .yamllint as a warning

# Treat these as warnings rather than hard failures for now:
#  - command-instead-of-module: legit `rpm -q` queries and `git` on the printer
warn_list:
  - command-instead-of-shell
  - no-changed-when
  # command-instead-of-module: native modules/facts now used everywhere the
  # conversion is clean (getenforce->ansible_selinux, id-u->getent,
  # rpm-q->package_facts). The two remaining legit queries (`which`,
  # `dnf repolist`) carry an inline `# noqa`.
