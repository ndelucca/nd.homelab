#!/usr/bin/env bash
# {{ ansible_managed }}
# Emite una alerta de renovación de certificado. Siempre loguea en el journal con
# prioridad error (visible vía `journalctl -t lego-renew`); además hace push a ntfy
# cuando hay una URL de topic configurada. El alerting nunca debe hacer fallar al
# llamador, así que cada push es best-effort.
# Uso: acme-notify.sh "<título>" "<mensaje>"
set -uo pipefail

title="${1:-Certificate renewal alert}"
message="${2:-(no details)}"

# 1) Journal (siempre). Etiquetado para poder buscarlo con grep o armar alertas journald.
logger -t lego-renew -p user.err -- "${title}: ${message}" 2>/dev/null \
  || echo "[lego-renew][ERROR] ${title}: ${message}" >&2

# 2) push ntfy (best-effort).
{% if acme_notify_ntfy_url %}
curl -fsS --max-time 15 \
  -H "Title: ${title}" \
  -H "Priority: high" \
  -H "Tags: warning,lock" \
  -d "${message}" \
  "{{ acme_notify_ntfy_url }}" >/dev/null 2>&1 \
  || logger -t lego-renew -p user.err -- "ntfy push failed for: ${title}"
{% endif %}

exit 0
