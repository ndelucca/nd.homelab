[Unit]
# No arrancar si el disco de appdata no está montado: si falta D-Draco, falla
# limpiamente en vez de escribir sobre el mountpoint vacío en root.
RequiresMountsFor={{ storage_appdata_disk }}

[Service]
User={{ jellyfin_user }}
Group={{ jellyfin_group }}

WorkingDirectory={{ jellyfin_data_dir }}

# Limpia el ExecStart original (el ExecStart= vacío resetea el del unit base).
ExecStart=

ExecStart=/usr/bin/jellyfin \
  --datadir {{ jellyfin_data_dir }} \
  --configdir {{ jellyfin_config_dir }} \
  --logdir {{ jellyfin_log_dir }} \
  --cachedir {{ jellyfin_cache_dir }}

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ jellyfin_base_dir }} {{ jellyfin_data_dir }} {{ jellyfin_config_dir }} {{ jellyfin_cache_dir }} {{ jellyfin_log_dir }} {{ jellyfin_media_dir }}

Restart=on-failure
RestartSec=5s
