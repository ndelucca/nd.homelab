# Uptime-Kuma Quadlet Unit File
# Managed by Ansible - DO NOT EDIT MANUALLY

[Unit]
Description=Uptime-Kuma Monitoring Pod
Documentation=https://github.com/louislam/uptime-kuma
After=network-online.target
Wants=network-online.target

[Kube]
# Path to Kubernetes YAML
Yaml={{ monitoring_data_dir }}/uptime-kuma-pod.yaml

# Set SELinux labels for volumes
SetWorkingDirectory=yaml

# Auto-update images
AutoUpdate=registry

[Service]
# Restart policy
Restart=on-failure
RestartSec=30
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
