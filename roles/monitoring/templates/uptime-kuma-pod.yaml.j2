# Uptime-Kuma Pod - Kubernetes YAML for Podman Quadlet
# Generated by Ansible - DO NOT EDIT MANUALLY
apiVersion: v1
kind: Pod
metadata:
  name: {{ monitoring_pod_name }}
  labels:
    app: uptime-kuma
spec:
  restartPolicy: Always

  # Share the host network namespace so the monitor can reach every service
  # directly on the host loopback (127.0.0.1:<port>) — the services bind to
  # localhost only, which a bridged rootless container cannot reach. Uptime-Kuma
  # is pinned to 127.0.0.1:{{ monitoring_port }} via the env vars below, so it
  # still listens on loopback only and stays behind NGINX (status.<domain>).
  hostNetwork: true

  containers:
  - name: uptime-kuma
    image: {{ monitoring_image }}
    env:
    - name: UPTIME_KUMA_HOST
      value: "{{ monitoring_host }}"
    - name: UPTIME_KUMA_PORT
      value: "{{ monitoring_port }}"
    volumeMounts:
    - name: data
      mountPath: /app/data

  volumes:
  - name: data
    hostPath:
      path: {{ monitoring_data_dir }}
      type: Directory
