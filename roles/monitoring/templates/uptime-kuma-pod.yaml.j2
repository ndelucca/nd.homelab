apiVersion: v1
kind: Pod
metadata:
  name: {{ monitoring_pod_name }}
  labels:
    app: uptime-kuma
spec:
  restartPolicy: Always

  containers:
  - name: uptime-kuma
    image: {{ monitoring_image }}
    ports:
    - containerPort: {{ monitoring_container_port }}
      hostPort: {{ monitoring_port }}
      hostIP: {{ monitoring_host }}
    volumeMounts:
    - name: data
      mountPath: /app/data

  volumes:
  - name: data
    hostPath:
      path: {{ monitoring_data_dir }}
      type: Directory
