#!/usr/bin/env bash
# {{ ansible_managed }}
# Restore drill mensual. Un backup que nunca restauraste es una hipótesis, no un
# backup, así que esto prueba que el repo es realmente restaurable: restaura los
# dumps (chicos y autoritativos) de las DBs del último snapshot a un directorio
# descartable y verifica que vuelvan no vacíos. Restaura SOLO los dumps, nunca los
# datos vivos, y no toca nada fuera de su directorio temporal.
#
# ALCANCE (deliberado): esto verifica que restic puede leer+desencriptar el repo y
# que los dumps vuelven no vacíos, NO que cada dump cargue limpiamente en un motor
# de DB nuevo. Validar el restore-into-DB (PRAGMA integrity_check / pg_restore) se
# dejó afuera a propósito: es un home-lab de un solo admin y la prioridad es
# simplemente TENER una segunda copia restaurable, no una verificación de nivel
# enterprise.
set -uo pipefail

export RESTIC_REPOSITORY="{{ backup_repo }}"
export RESTIC_PASSWORD_FILE="{{ backup_password_file }}"

log() { echo "[restore-drill] $*"; }
notify() {
{% if backup_notify_enabled %}
  "{{ backup_notify_script }}" "$1" "$2" || true
{% else %}
  echo "[restore-drill][ALERT] $1: $2" >&2
{% endif %}
}
fail() { log "ERROR: $1"; notify "Restore drill failed" "$1"; exit 1; }

mountpoint -q "{{ storage_backup_disk }}" || fail "backup disk {{ storage_backup_disk }} is not mounted"

tmp="$(mktemp -d)"
trap 'rm -rf "${tmp}"' EXIT

includes=(
{% for app in (['immich'] if backup_immich_enabled else []) + (backup_sqlite_dbs | map(attribute='app') | list) + (backup_copy_dbs | map(attribute='app') | list) %}
  --include "{{ app_data_root }}/{{ app }}/dumps"
{% endfor %}
)

log "restoring latest snapshot dumps into ${tmp}"
if ! restic restore latest --target "${tmp}" "${includes[@]}"; then
  fail "restic restore returned an error"
fi

# Probar que volvió algo real: al menos un archivo de dump no vacío.
found="$(find "${tmp}" -type f -size +0c | wc -l)"
if [ "${found}" -eq 0 ]; then
  fail "no non-empty dump files were restored from the latest snapshot"
fi

log "restore drill OK: ${found} dump file(s) restored and non-empty"
