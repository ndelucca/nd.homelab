#!/usr/bin/env bash
# {{ ansible_managed }}
# Backup diario: dumps consistentes de las DBs -> restic backup -> restic forget.
# Corre como {{ backup_user }} (rootless) vía la user unit backup.service.
set -euo pipefail

export RESTIC_REPOSITORY="{{ backup_repo }}"
export RESTIC_PASSWORD_FILE="{{ backup_password_file }}"

log() { echo "[backup] $*"; }
die() { echo "[backup][ERROR] $*" >&2; exit 1; }

# Falla diferida: un dump que falla NO debe abortar el resto del backup (el objetivo primario es
# tener una copia del resto de las apps + D-Leo). Se marca acá, se sigue, se corre restic igual, y
# al final se sale distinto de cero para que OnFailure=/notify avise que el snapshot salió degradado.
backup_degraded=0

# RequiresMountsFor no es confiable para user units (los mounts del sistema no
# son visibles para el user manager), así que se verifican los mounts de forma
# explícita antes de tocarlos.
mountpoint -q "{{ storage_backup_disk }}" || die "backup disk {{ storage_backup_disk }} is not mounted"
mountpoint -q "{{ storage_appdata_disk }}" || die "appdata disk {{ storage_appdata_disk }} is not mounted"

{% if backup_immich_enabled %}
# Immich PostgreSQL: dump lógico desde el container en ejecución (online, consistente).
IMMICH_DUMP="{{ app_data_root }}/immich/dumps/immich.sql.gz"
if podman ps --format '{% raw %}{{.Names}}{% endraw %}' | grep -qx "{{ backup_immich_container }}"; then
  log "dumping Immich Postgres -> ${IMMICH_DUMP}"
  if podman exec "{{ backup_immich_container }}" \
        pg_dump -U "{{ backup_immich_db_user }}" -d "{{ backup_immich_db_name }}" --clean --if-exists \
        | gzip -c > "${IMMICH_DUMP}.tmp" && [ -s "${IMMICH_DUMP}.tmp" ]; then
    mv -f "${IMMICH_DUMP}.tmp" "${IMMICH_DUMP}"
  else
    # No se aborta el backup entero: se conserva el dump anterior (si existe) y se marca degradado.
    rm -f "${IMMICH_DUMP}.tmp"
    log "WARNING: el dump de Immich falló o vino vacío — se respalda el dump previo si existe (backup DEGRADADO)"
    backup_degraded=1
  fi
else
  log "WARNING: el container {{ backup_immich_container }} no está corriendo — se saltea el dump de Immich (backup DEGRADADO)"
  backup_degraded=1
fi
{% endif %}

# Bases SQLite: .backup online (seguro mientras la app está corriendo).
{% for db in backup_sqlite_dbs %}
SRC="{{ db.path }}"
DEST="{{ app_data_root }}/{{ db.app }}/dumps/{{ db.app }}.db"
if [ -f "${SRC}" ]; then
  log "backing up {{ db.app }} SQLite -> ${DEST}"
  sqlite3 "${SRC}" ".backup '${DEST}.tmp'" || die ".backup failed for {{ db.app }}"
  [ -s "${DEST}.tmp" ] || die "{{ db.app }} SQLite backup is empty"
  mv -f "${DEST}.tmp" "${DEST}"
else
  log "WARNING: {{ db.app }} DB not found at ${SRC} — skipping"
fi
{% endfor %}

# BoltDB / bases de un solo archivo: copia de archivo consistente (Bolt es transaccional).
{% for db in backup_copy_dbs %}
SRC="{{ db.path }}"
DEST="{{ app_data_root }}/{{ db.app }}/dumps/{{ db.app }}.db"
if [ -f "${SRC}" ]; then
  log "copying {{ db.app }} DB -> ${DEST}"
  cp -p "${SRC}" "${DEST}.tmp" || die "copy failed for {{ db.app }}"
  [ -s "${DEST}.tmp" ] || die "{{ db.app }} DB copy is empty"
  mv -f "${DEST}.tmp" "${DEST}"
else
  log "WARNING: {{ db.app }} DB not found at ${SRC} — skipping"
fi
{% endfor %}

log "running restic backup"
set +e
restic backup \
  --verbose \
  --tag automated \
  --exclude-file "{{ backup_excludes_file }}" \
{% for path in backup_paths %}
  "{{ path }}"{% if not loop.last %} \{% endif %}

{% endfor %}
rc=$?
set -e
# exit codes de restic: 0 = ok, 3 = algunos archivos de origen no se pudieron leer (warning).
if [ "${rc}" -eq 0 ]; then
  log "backup completed"
elif [ "${rc}" -eq 3 ]; then
  log "WARNING: backup completed with unreadable files (rc=3)"
else
  die "restic backup failed (rc=${rc})"
fi

# Retención (solo forget; el prune corre semanalmente en maintenance).
# Se acota la retención a los snapshots 'automated' que crea este script (y se
# agrupa por ese tag) para que la política sea determinística y nunca olvide/
# conserve snapshots ad-hoc o futuros que usen otro conjunto de paths: sin --tag,
# forget agrupa por (host,paths) y un segundo conjunto de paths cambiaría la
# retención en silencio.
log "applying retention policy"
restic forget \
  --tag automated \
  --group-by tags \
  --keep-daily {{ backup_keep_daily }} \
  --keep-weekly {{ backup_keep_weekly }} \
  --keep-monthly {{ backup_keep_monthly }}

# Si algún dump se saltó/falló, el backup del resto igual corrió; se marca la unit como fallada
# (OnFailure=backup-notify@) para que la falla no pase inadvertida.
[ "${backup_degraded}" -eq 0 ] || die "backup completó pero un dump de DB se saltó/falló (ver WARNING arriba)"

log "done"
