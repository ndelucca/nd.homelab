# Deshabilita el DNSStubListener de systemd-resolved para liberar el puerto 53 para AdGuard Home.

[Resolve]
{% if adguard_resolved_dns_servers %}
DNS={{ adguard_resolved_dns_servers | join(' ') }}
{% endif %}
{% if adguard_resolved_fallback_dns %}
FallbackDNS={{ adguard_resolved_fallback_dns | join(' ') }}
{% endif %}
DNSStubListener=no
