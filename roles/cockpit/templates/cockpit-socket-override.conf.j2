# Managed by Ansible (cockpit role).
# Bindea Cockpit solo a localhost: es alcanzable únicamente a través del vhost 443
# de NGINX (cockpit.{{ nginx_domain | default('') }}), nunca directamente en la LAN.
# El ListenStream= vacío primero limpia el default 0.0.0.0:9090 de la unit.
[Socket]
ListenStream=
ListenStream=127.0.0.1:{{ cockpit_port }}
