# Drop-in to ensure AdGuard waits for network and auto-restarts on failure
[Unit]
After=network-online.target
Wants=network-online.target

[Service]
# Wait until the LAN gateway actually answers (bounded), instead of a fixed
# blind sleep. Exits as soon as the gateway pings; gives up after the bounded
# number of tries and lets AdGuard start anyway (readiness is best-effort, must
# never wedge DNS/DHCP startup).
ExecStartPre=/bin/sh -c 'for i in $(seq 1 {{ service_maintenance_network_wait_tries }}); do ping -c1 -W1 {{ service_maintenance_gateway_ip }} >/dev/null 2>&1 && exit 0; sleep 1; done; exit 0'
# Auto-restart on failure
Restart=on-failure
RestartSec={{ service_maintenance_adguard_restart_delay }}
