[Unit]
Description=Home Assistant Container
After=network-online.target
Wants=network-online.target

[Container]
Image={{ home_assistant_image }}
ContainerName=home_assistant
PublishPort={{ home_assistant_host }}:{{ home_assistant_port }}:8123

# Volumen de config. Sin relabel :z/:Z: el selinux.yml del role (vía container_base) es
# dueño del label persistente container_file_t sobre home_assistant_config_dir. Un :Z acá
# estamparía una categoría MCS por container que el próximo restorecon/relabel revierte,
# causando permission-denied intermitentes (mismo patrón que kavita).
Volume={{ home_assistant_config_dir }}:/config

Environment=TZ={{ home_assistant_timezone }}

[Service]
Restart=on-failure
RestartSec=30
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target default.target
