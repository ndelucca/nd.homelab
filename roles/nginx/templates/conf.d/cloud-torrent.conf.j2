# Usa Server-Sent Events (SSE) en /sync, no WebSockets, así que no lleva headers
# de upgrade.

server {
    listen 80;
    server_name torrent.{{ nginx_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name torrent.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Headers de seguridad TLS compartidos (fuente única: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    location / {
        proxy_pass http://127.0.0.1:{{ nginx_cloud_torrent_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
    }

    # Endpoint de Server-Sent Events (SSE) para actualizaciones en tiempo real
    location /sync {
        proxy_pass http://127.0.0.1:{{ nginx_cloud_torrent_port }}/sync;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Ajustes específicos de SSE
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_http_version 1.1;
        chunked_transfer_encoding off;
    }
}
