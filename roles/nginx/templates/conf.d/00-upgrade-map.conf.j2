# Managed by Ansible - DO NOT EDIT MANUALLY
# Single global map for WebSocket upgrade, shared by every vhost. With this,
# `proxy_set_header Connection $connection_upgrade;` sends "upgrade" only for
# real WebSocket requests and "close"/keepalive otherwise — unlike the static
# `Connection "upgrade"` antipattern, which forced upgrade on every request.
# Loaded first (00-) so it is defined before any vhost references it.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
