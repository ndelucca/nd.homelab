# Managed by Ansible - DO NOT EDIT MANUALLY
# Map global única para el upgrade de WebSocket, compartida por todos los vhost.
# Con esto, `proxy_set_header Connection $connection_upgrade;` envía "upgrade"
# solo en las peticiones WebSocket reales y "close"/keepalive en el resto, a
# diferencia del antipatrón estático `Connection "upgrade"`, que forzaba el
# upgrade en cada petición.
# Se carga primero (00-) para que quede definida antes de que cualquier vhost la
# referencie.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
