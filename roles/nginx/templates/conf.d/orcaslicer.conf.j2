# Contenedor basado en KasmVNC; WebCodecs requiere HTTPS.
# (la map $connection_upgrade se define globalmente en conf.d/00-upgrade-map.conf)

server {
    listen 80;
    server_name slicer.{{ nginx_domain }};

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    # http2 deshabilitado: puede causar problemas con el streaming de WebSocket
    server_name slicer.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Sin límite de tamaño para las subidas
    client_max_body_size 0;

    # Headers de seguridad TLS compartidos (fuente única: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    location / {
        # Proxy al puerto HTTPS del contenedor (cert self-signed)
        proxy_pass https://127.0.0.1:{{ nginx_orcaslicer_port }};
        proxy_ssl_verify off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # Soporte de WebSocket (crítico para KasmVNC)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Timeouts largos para las sesiones de streaming (30 minutos)
        proxy_connect_timeout 1800s;
        proxy_read_timeout 1800s;
        proxy_send_timeout 1800s;

        # Sin buffering para el streaming en tiempo real
        proxy_buffering off;
        proxy_request_buffering off;
    }
}
