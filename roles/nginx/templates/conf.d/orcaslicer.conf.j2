# ========================================
# ORCASLICER (3D SLICER) SUBDOMAIN
# ========================================
# KasmVNC-based container - HTTPS required for WebCodecs
# ($connection_upgrade map is defined globally in conf.d/00-upgrade-map.conf)

# HTTP - Redirect to HTTPS
server {
    listen 80;
    server_name slicer.{{ nginx_domain }};

    return 301 https://$host$request_uri;
}

# HTTPS
server {
    listen 443 ssl;
    # Note: http2 disabled - can cause issues with WebSocket streaming
    server_name slicer.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # No body size limit for uploads
    client_max_body_size 0;

    # Shared TLS security headers (single source: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    location / {
        # Proxy to container's HTTPS port (self-signed cert)
        proxy_pass https://127.0.0.1:{{ nginx_orcaslicer_port }};
        proxy_ssl_verify off;

        # Required headers for KasmVNC
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # WebSocket support (critical for KasmVNC)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Long timeouts for streaming sessions (30 minutes)
        proxy_connect_timeout 1800s;
        proxy_read_timeout 1800s;
        proxy_send_timeout 1800s;

        # Disable buffering for real-time streaming
        proxy_buffering off;
        proxy_request_buffering off;
    }
}
