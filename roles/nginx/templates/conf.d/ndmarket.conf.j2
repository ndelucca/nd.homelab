# ========================================
# ND.MARKET SUBDOMAIN
# ========================================
# Reverse proxy for nd.markets (app on 127.0.0.1:{{ nginx_ndmarket_port }}).
# The app exposes Server-Sent Events on /stream/{symbol}: it needs
# proxy_buffering off and a long read timeout, or live prices don't come through.

# HTTP - redirect to HTTPS
server {
    listen 80;
    server_name market.{{ nginx_domain }};
    return 301 https://$host$request_uri;
}

# HTTPS
server {
    listen 443 ssl;
    http2 on;
    server_name market.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Shared TLS security headers (single source: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    # Compression (gzip is enough for the static assets).
    gzip            on;
    gzip_types      text/css application/javascript application/json;
    gzip_min_length 1024;

    location / {
        proxy_pass         http://127.0.0.1:{{ nginx_ndmarket_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Host  $host;
        proxy_set_header   Connection        "";

        # Server-Sent Events: no buffering and a long timeout.
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 1h;
    }
}
