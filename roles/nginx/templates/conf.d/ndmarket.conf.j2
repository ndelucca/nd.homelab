# Reverse proxy para nd.markets (la app corre en 127.0.0.1:{{ nginx_ndmarket_port }}).
# La app expone Server-Sent Events en /stream/{symbol}: necesita proxy_buffering
# off y un read timeout largo, o si no los precios en vivo no llegan.

server {
    listen 80;
    server_name market.{{ nginx_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name market.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Headers de seguridad TLS compartidos (fuente única: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    # Compresión (gzip alcanza para los assets estáticos).
    gzip            on;
    gzip_types      text/css application/javascript application/json;
    gzip_min_length 1024;

    location / {
        proxy_pass         http://127.0.0.1:{{ nginx_ndmarket_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Host  $host;
        proxy_set_header   Connection        "";

        # Server-Sent Events: sin buffering y con un timeout largo.
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 1h;
    }
}
