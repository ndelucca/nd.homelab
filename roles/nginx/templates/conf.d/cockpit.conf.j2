# ========================================
# COCKPIT SUBDOMAIN
# ========================================

# HTTP - redirect to HTTPS (Cockpit sets Secure cookies which require HTTPS)
server {
    listen 80;
    server_name cockpit.{{ nginx_domain }};
    return 301 https://$host$request_uri;
}

# HTTPS
server {
    listen 443 ssl;
    http2 on;
    server_name cockpit.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        # Cockpit listens on 127.0.0.1:9090 (bound localhost by the cockpit role);
        # AllowUnencrypted is safe because only this proxy can reach it.
        proxy_pass http://127.0.0.1:{{ nginx_cockpit_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        # WebSocket support for Cockpit
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Preserve ETag
        gzip off;
    }
}
