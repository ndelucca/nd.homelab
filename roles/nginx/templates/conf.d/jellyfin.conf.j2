server {
    listen 80;
    server_name jellyfin.{{ nginx_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name jellyfin.{{ nginx_domain }};

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # Permite subir archivos de media grandes
    client_max_body_size 20G;

    # Headers de seguridad TLS compartidos (fuente única: ssl_headers.inc.j2)
    include {{ nginx_ssl_headers_snippet }};

    # CSP para los metadatos de YouTube y Chromecast
    add_header Content-Security-Policy "default-src 'self' 'unsafe-inline' https://www.youtube.com https://i.ytimg.com https://www.gstatic.com" always;

    location / {
        proxy_pass http://127.0.0.1:{{ nginx_jellyfin_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    # Endpoint WebSocket de SyncPlay de Jellyfin
    location /socket {
        proxy_pass http://127.0.0.1:{{ nginx_jellyfin_port }}/socket;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
