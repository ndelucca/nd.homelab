#!/usr/bin/python3
# {{ ansible_managed }}
#
# home-claude — handler por conexión del bridge (socket-activation, Accept=yes).
# Gestionado por Ansible (rol claude_bridge) — no editar a mano.
#
# stdin y stdout SON el socket. El cliente escribe un objeto JSON, hace half-close, y lee la
# respuesta hasta EOF. La respuesta es siempre el envelope de `claude -p --output-format json`;
# ante cualquier error propio devolvemos un envelope sintético con is_error, para que el cliente
# tenga un único formato que parsear.
#
# El stderr del CLI NUNCA se reenvía al socket (corrompería el JSON): va al journal.
# Al journal tampoco van el prompt ni el result — son datos de la app.

import fcntl
import json
import os
import subprocess
import sys
import time

BIN = {{ claude_bridge_bin | to_json }}
SETTINGS = {{ claude_bridge_settings_path | to_json }}
WORKDIR = {{ claude_bridge_workdir | to_json }}
LOCK_PATH = {{ claude_bridge_lock_path | to_json }}

CALL_TIMEOUT = {{ claude_bridge_call_timeout | int }}
LOCK_TIMEOUT = {{ claude_bridge_lock_timeout | int }}
MAX_PROMPT = {{ claude_bridge_max_prompt_bytes | int }}
MAX_SYSTEM = {{ claude_bridge_max_system_bytes | int }}

DEFAULT_MODEL = {{ claude_bridge_default_model | to_json }}
ALLOWED_MODELS = {{ claude_bridge_allowed_models | to_json }}
DENIED_TOOLS = {{ claude_bridge_denied_tools | to_json }}

ALLOWED_KEYS = {"prompt", "system", "model"}
MAX_REQUEST = MAX_PROMPT + MAX_SYSTEM + 4096


def log(msg):
    print("home-claude: " + msg, file=sys.stderr, flush=True)


def respond(envelope):
    """Escribe el envelope al socket y cierra el lado de escritura."""
    sys.stdout.buffer.write(json.dumps(envelope).encode())
    sys.stdout.buffer.flush()
    sys.exit(0)


def fail(motivo):
    log("rechazado: " + motivo)
    respond({
        "type": "result",
        "subtype": "error",
        "is_error": True,
        "result": "home-claude: " + motivo,
        "session_id": "",
        "total_cost_usd": 0.0,
    })


def leer_request():
    # +1 byte para detectar el desborde en vez de truncar en silencio.
    raw = sys.stdin.buffer.read(MAX_REQUEST + 1)
    if len(raw) > MAX_REQUEST:
        fail("request demasiado grande (max %d bytes)" % MAX_REQUEST)
    if not raw.strip():
        fail("request vacío")
    try:
        req = json.loads(raw)
    except ValueError as exc:
        fail("request no es JSON válido: %s" % exc)
    if not isinstance(req, dict):
        fail("request debe ser un objeto JSON")
    return req


def validar(req):
    desconocidas = set(req) - ALLOWED_KEYS
    if desconocidas:
        fail("claves no permitidas: %s" % ", ".join(sorted(desconocidas)))

    prompt = req.get("prompt")
    if not isinstance(prompt, str) or not prompt.strip():
        fail("'prompt' es requerido y debe ser un string no vacío")
    if len(prompt.encode()) > MAX_PROMPT:
        fail("'prompt' supera %d bytes" % MAX_PROMPT)

    system = req.get("system", "")
    if not isinstance(system, str):
        fail("'system' debe ser un string")
    if len(system.encode()) > MAX_SYSTEM:
        fail("'system' supera %d bytes" % MAX_SYSTEM)

    # Allowlist exacta, nunca un regex: 'model' termina en argv del CLI.
    model = req.get("model") or DEFAULT_MODEL
    if model not in ALLOWED_MODELS:
        fail("modelo no permitido: %r (permitidos: %s)" % (model, ", ".join(ALLOWED_MODELS)))

    return prompt, system, model


def tomar_lock():
    """Serializa TODAS las consultas del host.

    El CLI reescribe ~/.claude/.credentials.json al refrescar el token OAuth, y los refresh
    tokens rotan: dos invocaciones concurrentes pueden dejar el archivo inservible para todas
    las apps. El lock se sostiene durante toda la ejecución del CLI.
    """
    fd = os.open(LOCK_PATH, os.O_RDWR | os.O_CREAT, 0o600)
    limite = time.monotonic() + LOCK_TIMEOUT
    while True:
        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return fd
        except OSError:
            if time.monotonic() >= limite:
                os.close(fd)
                fail("el bridge está ocupado (timeout de %ds esperando el lock)" % LOCK_TIMEOUT)
            time.sleep(0.5)


def construir_argv(prompt, system, model):
    argv = [
        BIN,
        "-p", prompt,
        "--output-format", "json",
        "--model", model,
        # settings.json es la fuente de verdad del tool-gating (root, no spoofeable desde el
        # prompt); los flags de abajo son el cinturón sobre los tiradores.
        "--settings", SETTINGS,
        "--strict-mcp-config",
        "--mcp-config", json.dumps({"mcpServers": {}}),
        "--permission-mode", "default",
    ]
    if DENIED_TOOLS:
        argv += ["--disallowed-tools"] + DENIED_TOOLS
    if system.strip():
        argv += ["--append-system-prompt", system]
    return argv


def main():
    req = leer_request()
    prompt, system, model = validar(req)

    lock_fd = tomar_lock()
    arranque = time.monotonic()
    try:
        proc = subprocess.run(  # noqa: S603 — argv en forma de lista, nunca shell
            construir_argv(prompt, system, model),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=CALL_TIMEOUT,
            cwd=WORKDIR,
            check=False,
        )
    except subprocess.TimeoutExpired:
        fail("la consulta superó el tope de %ds" % CALL_TIMEOUT)
    except OSError as exc:
        fail("no se pudo ejecutar el CLI: %s" % exc)
    finally:
        os.close(lock_fd)

    duracion = time.monotonic() - arranque

    if proc.returncode != 0:
        log("el CLI salió con %d en %.1fs" % (proc.returncode, duracion))
        log("stderr del CLI: %s" % proc.stderr.decode(errors="replace").strip()[:500])
        fail("el CLI falló (exit %d)" % proc.returncode)

    try:
        envelope = json.loads(proc.stdout)
    except ValueError:
        log("el CLI no devolvió JSON (%d bytes)" % len(proc.stdout))
        fail("la salida del CLI no es JSON válido")

    # Sólo metadata al journal: ni el prompt ni el result.
    log("ok en %.1fs (model=%s session=%s costo=%s error=%s)" % (
        duracion, model,
        envelope.get("session_id", "?"),
        envelope.get("total_cost_usd", "?"),
        envelope.get("is_error", "?"),
    ))
    respond(envelope)


if __name__ == "__main__":
    main()
