# Immich Quadlet Unit File
# Managed by Ansible - DO NOT EDIT MANUALLY

[Unit]
Description=Immich Photo Management Pod
Documentation=https://docs.immich.app
After=network-online.target
Wants=network-online.target

[Kube]
Yaml={{ immich_config_dir }}/immich-pod.yaml

# Corre la unit desde el directorio del YAML. NOTA: esto NO hace relabel de los volúmenes.
# El selinux.yml del role fija el fcontext (container_file_t) y dispara el relabel SOLO cuando
# cambia la fcontext DB (primer run); el relabel-en-restart de cada bump de imagen lo notifican
# configure.yml y quadlet.yml (handler `Container apply selinux context`, antes del restart).
# La imagen está pineada vía immich_version; sin AutoUpdate (reproducible).
SetWorkingDirectory=yaml

[Service]
Restart=on-failure
RestartSec=30
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
