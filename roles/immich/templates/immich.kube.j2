# Immich Quadlet Unit File
# Managed by Ansible - DO NOT EDIT MANUALLY

[Unit]
Description=Immich Photo Management Pod
Documentation=https://docs.immich.app
After=network-online.target
Wants=network-online.target

[Kube]
# Path to Kubernetes YAML
Yaml={{ immich_config_dir }}/immich-pod.yaml

# Run the unit from the YAML's directory. NOTE: this does NOT relabel volumes;
# SELinux labeling is handled by the role's selinux.yml (container_file_t on the
# data dirs). Image is pinned via immich_version; no AutoUpdate (reproducible).
SetWorkingDirectory=yaml

[Service]
# Restart policy
Restart=on-failure
RestartSec=30
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
