[Unit]
Description=Forgejo Git Forge Container
Documentation=https://forgejo.org/docs/
After=network-online.target
Wants=network-online.target

[Container]
Image={{ forgejo_image }}
ContainerName={{ forgejo_container_name }}

# Mapeo rootless: se mapea el usuario de servicio del host (uid {{ forgejo_uid }}) al
# usuario git del container para que sea dueño de los volúmenes montados. La imagen
# -rootless corre directamente como git (sin s6/drop de privilegios de root), así que
# keep-id funciona limpiamente acá.
UserNS=keep-id:uid={{ forgejo_uid }},gid={{ forgejo_uid }}

# HTTP servido vía NGINX (solo localhost); git SSH expuesto únicamente en la IP de
# la LAN (no en 0.0.0.0, para que nunca quede en otra interfaz). Este es el propio
# servidor SSH del container, independiente del sshd del host (puerto 22).
PublishPort={{ forgejo_host }}:{{ forgejo_port }}:3000
PublishPort={{ forgejo_ssh_host }}:{{ forgejo_ssh_port }}:2222

Volume={{ forgejo_data_dir }}:/var/lib/gitea:Z
Volume={{ forgejo_config_dir }}:/etc/gitea:Z

Environment=TZ={{ forgejo_timezone }}

# Configuración de la aplicación (se escribe en /etc/gitea/app.ini y persiste).
Environment=FORGEJO__server__DOMAIN={{ forgejo_domain }}
Environment=FORGEJO__server__ROOT_URL={{ forgejo_root_url }}
Environment=FORGEJO__server__SSH_DOMAIN={{ forgejo_domain }}
Environment=FORGEJO__server__SSH_PORT={{ forgejo_ssh_port }}
Environment=FORGEJO__server__SSH_LISTEN_PORT=2222
Environment=FORGEJO__server__HTTP_PORT=3000
Environment=FORGEJO__database__DB_TYPE=sqlite3
Environment=FORGEJO__service__DISABLE_REGISTRATION={{ forgejo_disable_registration | string | lower }}
Environment=FORGEJO__security__INSTALL_LOCK=true

[Service]
Restart=on-failure
RestartSec=30
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target
